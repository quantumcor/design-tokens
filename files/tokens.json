{
  "brand": {
    "blue": { "light": "#D9E5FF", "DEFAULT": "#2D62FF", "dark": "#080331" },
    "pink": { "light": "#FFAEFE", "DEFAULT": "#DD23BB", "dark": "#3C043B" }
  },
  "neutral": {
    "black": "#000000",
    "white": "#FFFFFF",
    "lightest": "#EEEEEE",
    "lighter": "#CCCCCC",
    "light": "#AAAAAA",
    "DEFAULT": "#666666",
    "dark": "#444444",
    "darker": "#222222",
    "darkest": "#111111"
  },
  "system": {
    "success": { "light": "#CEF5CA", "dark": "#114E0B" },
    "warning": { "light": "#FCF8D8", "dark": "#5E5515" },
    "error": { "light": "#F8E4E4", "dark": "#3B0B0B" },
    "focus": "#2D62FF"
  },
  "semantic": {
    "background": {
      "primary": "var(--neutral-black)",
      "secondary": "var(--brand-blue)",
      "tertiary": "var(--brand-pink)",
      "alternate": "var(--neutral-white)"
    },
    "text": {
      "primary": "var(--neutral-black)",
      "secondary": "var(--neutral-darker)",
      "alternate": "var(--neutral-white)"
    },
    "border": {
      "primary": "var(--neutral-lightest)",
      "secondary": "var(--brand-blue)",
      "alternate": "var(--neutral-darker)"
    },
    "link": {
      "primary": "var(--brand-blue)",
      "secondary": "var(--neutral-black)",
      "alternate": "var(--neutral-white)"
    }
  },
  "typography": {
    "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "fontSize": {
      "base": "1rem",
      "tiny": "0.75rem",
      "small": "0.875rem",
      "regular": "1rem",
      "medium": "1.25rem",
      "large": "1.5rem"
    },
    "lineHeight": { "base": "1.5" },
    "headings": {
      "h1": { "size": "4rem", "lineHeight": "1.1", "weight": "700" },
      "h2": { "size": "3rem", "lineHeight": "1.2", "weight": "700" },
      "h3": { "size": "2rem", "lineHeight": "1.2", "weight": "700" },
      "h4": { "size": "1.5rem", "lineHeight": "1.4", "weight": "700" },
      "h5": { "size": "1.25rem", "lineHeight": "1.5", "weight": "700" },
      "h6": { "size": "1rem", "lineHeight": "1.5", "weight": "700" }
    }
  },
  "spacing": {
    "tiny": "0.125rem",
    "xxsmall": "0.25rem",
    "xsmall": "0.5rem",
    "small": "1rem",
    "custom1": "1.5rem",
    "medium": "2rem",
    "custom2": "2.5rem",
    "large": "3rem",
    "custom3": "3.5rem",
    "xlarge": "4rem",
    "xxlarge": "5rem",
    "huge": "6rem",
    "xhuge": "8rem",
    "xxhuge": "12rem"
  },
  "layout": {
    "section": { "small": "3rem", "medium": "5rem", "large": "8rem" },
    "paddingGlobal": "2.5rem",
    "container": { "small": "48rem", "medium": "64rem", "large": "80rem" }
  },
  "radii": {
    "button": "0.25rem",
    "card": "0.25rem"
  }
}
