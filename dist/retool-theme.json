{
  "name": "QuantumCor Dark",
  "version": "1.0.0",
  "colors": {
    "primary": "#2369FE",
    "primaryHover": "#4A85FE",
    "background": "#090909",
    "surface": "#111111",
    "surfaceHover": "#1A1A1A",
    "border": "#333333",
    "borderSubtle": "#222222",
    "textPrimary": "#FBFBFB",
    "textSecondary": "#CCCCCC",
    "textTertiary": "#AAAAAA",
    "textDisabled": "#444444",
    "textLink": "#2369FE",
    "textOnPrimary": "#FFFFFF",
    "success": "#059669",
    "successLight": "#D1FAE5",
    "warning": "#D97706",
    "warningLight": "#FEF3C7",
    "error": "#DC2626",
    "errorLight": "#FEE2E2",
    "overlay": "rgba(0, 0, 0, 0.7)"
  },
  "typography": {
    "fontFamily": "'Montserrat', sans-serif",
    "monoFontFamily": "'Inconsolata', monospace",
    "sizes": {
      "hero": "3rem",
      "display": "2.5rem",
      "h1": "2.25rem",
      "h2": "1.5rem",
      "h3": "1.25rem",
      "lg": "1.125rem",
      "base": "1rem",
      "sm": "0.875rem",
      "xs": "0.7rem",
      "xxs": "0.6rem"
    }
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem",
    "section": "5rem",
    "container": "1.5rem"
  },
  "borderRadius": {
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "pill": "100px"
  },
  "shadows": {
    "sm": "0 1px 2px rgba(0, 0, 0, 0.3)",
    "md": "0 4px 12px rgba(0, 0, 0, 0.4)",
    "lg": "0 8px 24px rgba(0, 0, 0, 0.5)",
    "glow-blue": "0 0 20px rgba(35, 105, 254, 0.15)",
    "glow-blue-strong": "0 0 40px rgba(35, 105, 254, 0.25)"
  },
  "components": {
    "button": {
      "primary": {
        "bg": "#2369FE",
        "text": "#FFFFFF",
        "radius": "100px",
        "padding": "10px 20px",
        "font": "'Montserrat', sans-serif",
        "fontSize": "1rem",
        "fontWeight": "500",
        "hover-bg": "#4A85FE"
      },
      "secondary": {
        "bg": "transparent",
        "text": "#FBFBFB",
        "border": "1px solid #333333",
        "radius": "100px",
        "padding": "10px 20px",
        "hover-bg": "rgba(251, 251, 251, 0.05)"
      },
      "danger": {
        "bg": "#DC2626",
        "text": "#FFFFFF",
        "radius": "100px"
      }
    },
    "card": {
      "bg": "#111111",
      "border": "1px solid #333333",
      "radius": "12px",
      "padding": "24px",
      "hover-shadow": "0 0 20px rgba(35, 105, 254, 0.15)"
    },
    "input": {
      "bg": "#1A1A1A",
      "border": "1px solid #333333",
      "radius": "8px",
      "padding": "10px 16px",
      "text": "#FBFBFB",
      "placeholder": "#444444",
      "focus-border": "#2369FE",
      "focus-ring": "0 0 0 3px rgba(35, 105, 254, 0.15)"
    },
    "nav": {
      "bg": "#090909",
      "text": "#FBFBFB",
      "link-hover": "#2369FE",
      "height": "64px"
    },
    "badge": {
      "radius": "100px",
      "padding": "4px 12px",
      "fontSize": "0.7rem",
      "fontWeight": "600",
      "letterSpacing": "0.06em",
      "textTransform": "uppercase"
    }
  },
  "_retoolCustomCSS": "/* Paste into Retool > Settings > Custom CSS */\n:root {\n  --retool-primary: #2369FE;\n  --retool-bg: #090909;\n  --retool-surface: #111111;\n  --retool-border: #333333;\n  --retool-text: #FBFBFB;\n  --retool-text-secondary: #CCCCCC;\n}\n.retool-canvas { background: var(--retool-bg) !important; }\n.retool-widget-container { \n  background: var(--retool-surface) !important; \n  border-color: var(--retool-border) !important;\n  border-radius: 0.75rem !important;\n}"
}